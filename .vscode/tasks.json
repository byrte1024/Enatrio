        {
            "label": "Clean Build",
            "type": "shell",
            "command": "C:\\msys64\\usr\\bin\\bash.exe",
            "args": [
                "--login",
                "-c",
                "cd /c/Users/User/repos/Enatrio && rm -rf build"
            ],
            "problemMatcher": [],
            "detail": "Remove all build artifacts"
        },
        {
            "label": "Preprocess Current File",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-E",
                "-P",
                "-std=c23",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.i"
            ],
            "problemMatcher": [],
            "detail": "Show preprocessor output (macros expanded) - creates .i file"
        },
        {
            "label": "Preprocess Current File (with line markers)",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-E",
                "-std=c23",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.i"
            ],
            "problemMatcher": [],
            "detail": "Show preprocessor output with line markers - creates .i file"
        },
        {
            "label": "Generate compile_commands.json",
