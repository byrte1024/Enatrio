            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Build project in release mode with optimizations"
        },
        {
            "label": "Build and Run Debug",
            "type": "shell",
            "command": "C:\\msys64\\usr\\bin\\bash.exe",
            "args": [
                "--login",
                "-c",
                "cd /c/Users/User/repos/Enatrio && ./build.sh debug && ./build/debug/Enatrio.exe"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Build in debug mode and run the executable"
        },
